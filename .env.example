# MongoDB connection (local mongod, or a MongoDB Atlas URI)
MONGODB_URI="mongodb://127.0.0.1:27017"
MONGODB_DB="guriescapes"

# Admin login (required in production)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-password"

# Signs the admin session cookie (required in production).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET="change-this-to-a-long-random-string"

# Vercel Blob — image uploads in the admin. Create a Blob store in the Vercel
# dashboard (Storage → Blob); the token is auto-injected on Vercel. For local
# dev, paste it here. Without it, admins can still add images by URL.
BLOB_READ_WRITE_TOKEN=""
