# MongoDB connection (local mongod, or a MongoDB Atlas URI)
MONGODB_URI="mongodb://127.0.0.1:27017"
MONGODB_DB="guriescapes"

# Admin login (required in production)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-password"

# Signs the admin session cookie (required in production).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET="change-this-to-a-long-random-string"

# Email notifications (Resend). Get a key at resend.com, verify guriescapes.com,
# then set MAIL_FROM to a verified address. Without RESEND_API_KEY, the site
# still works — it just skips sending. MAIL_TO defaults to the site contact email.
RESEND_API_KEY=""
MAIL_FROM="Guri Escapes <hello@guriescapes.com>"
MAIL_TO=""

# Image uploads are stored in MongoDB by default (served via /api/img/[id]),
# so no extra config is needed. Optionally, set a Vercel Blob token to store
# uploads on Vercel's CDN instead (Storage → Blob; auto-injected on Vercel).
BLOB_READ_WRITE_TOKEN=""
